generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PROJECT_MANAGER
  DEVELOPER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdProjects Project[]      @relation("ProjectCreator")
  assignedTasks   Task[]         @relation("TaskAssignee")
  activities      Activity[]
  notifications   Notification[]
  refreshTokens   RefreshToken[]

  @@index([email])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  clientName  String
  description String?
  createdById Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy  User       @relation("ProjectCreator", fields: [createdById], references: [id])
  tasks      Task[]
  activities Activity[]

  @@index([createdById])
}

model Task {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  isOverdue   Boolean      @default(false)
  projectId   Int
  assignedTo  Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedUser  User?          @relation("TaskAssignee", fields: [assignedTo], references: [id])
  activities    Activity[]
  notifications Notification[]

  @@index([projectId])
  @@index([assignedTo])
  @@index([status])
  @@index([dueDate])
  @@index([isOverdue])
}

model Activity {
  id        Int      @id @default(autoincrement())
  action    String
  taskId    Int?
  projectId Int
  userId    Int
  metadata  Json?
  createdAt DateTime @default(now())

  task    Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([projectId, createdAt])
  @@index([userId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  message   String
  type      String
  taskId    Int?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}
